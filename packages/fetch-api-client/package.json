      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "description": "A lightweight, framework-agnostic HTTP client built on the native Fetch API.",
  "keywords": [
    "fetch",
    "http-client",
    "middleware",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/il421/fe-libs.git",
    "directory": "packages/fetch-api-client"
  },
  "homepage": "https://github.com/il421/fe-libs/tree/main/packages/fetch-api-client#readme",
  "bugs": {
    "url": "https://github.com/il421/fe-libs/issues"
  },
  "scripts": {
    "fetch-api-client:build": "nx run @fe-libs/fetch-api-client:build",
    "fetch-api-client:publish": "nx run @fe-libs/fetch-api-client:nx-release-publish"
  },
  "dependencies": {}
}
